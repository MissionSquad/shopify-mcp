{
  "name": "@missionsquad/mcp-shopify",
  "version": "2.1.1",
  "description": "MCP Server for Shopify API, enabling interaction with store data through GraphQL API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "mcp-shopify": "./dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "yarn test && yarn build"
  },
  "keywords": [
    "shopify",
    "mcp",
    "model-context-protocol",
    "graphql",
    "ai",
    "llm",
    "missionsquad"
  ],
  "author": "Mission Squad AI <jayson@missionsquad.ai>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@missionsquad/fastmcp": "^1.1.3",
    "dotenv": "^16.4.7",
    "graphql": "^16.6.0",
    "graphql-request": "^5.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
