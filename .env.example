# Shopify MCP Server Configuration
# For local development only. In production, secrets are injected via mcp-api.

# Option 1: Static access token (legacy Shopify apps)
SHOPIFY_ACCESS_TOKEN=

# Option 2: Client credentials (Shopify Dev Dashboard apps, Jan 2026+)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Required: Your store's myshopify.com domain
MYSHOPIFY_DOMAIN=your-store.myshopify.com

# Optional: Shopify API version (default: 2026-01)
SHOPIFY_API_VERSION=2026-01

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
